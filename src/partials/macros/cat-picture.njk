{% macro catPicture(image, index, lazyThreshold, altText) %}
<picture>
	<source
		srcset="/images/cats/avif/{{ image.name.replace('.jpg', '.avif') }}"
		type="image/avif"
	/>
	<source
		srcset="/images/cats/webp/{{ image.name.replace('.jpg', '.webp') }}"
		type="image/webp"
	/>
	<img
		src="/images/cats/{{ image.name }}"
		alt="{{ altText }}"
		width="{{ image.width }}"
		height="{{ image.height }}"
		class="cmp-special-image cmp-special-image--{{ image.orientation }}"
		{% if index > lazyThreshold %}loading="lazy"{% endif %}>
</picture>
{% endmacro %}
